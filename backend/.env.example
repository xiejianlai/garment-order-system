# 数据库连接 (本地开发用MySQL，云部署用PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/garment_order"

# JWT 密钥
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 微信小程序配置
WX_APPID="your-wx-appid"
WX_SECRET="your-wx-secret"

# 文件上传配置 (腾讯云COS)
COS_SECRET_ID="your-cos-secret-id"
COS_SECRET_KEY="your-cos-secret-key"
COS_BUCKET="your-bucket-1250000000"
COS_REGION="ap-guangzhou"

# 服务端口
PORT=3000
